# Copy this file to .env and fill in your values before running the app.
# .env is gitignored — never commit real secrets.

# Gemini API key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Gmail OAuth access token — short-lived (~1 hour), refresh before each demo run
# 1. Open https://developers.google.com/oauthplayground
# 2. In the left panel, find "Gmail API v1" → tick https://www.googleapis.com/auth/gmail.readonly
# 3. Click "Authorize APIs" and sign in with your Gmail account
# 4. Click "Exchange authorization code for tokens"
# 5. Copy the value from the "Access token" field (starts with ya29.)
# 6. Paste it below
GMAIL_ACCESS_TOKEN=""
